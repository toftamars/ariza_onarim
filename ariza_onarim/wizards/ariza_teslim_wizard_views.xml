<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ariza_teslim_wizard_form" model="ir.ui.view">
        <field name="name">ariza.teslim.wizard.form</field>
        <field name="model">ariza.teslim.wizard</field>
        <field name="arch" type="xml">
            <form string="Teslim Alan Bilgisi">
                <field name="ariza_id" invisible="1"/>
                <field name="garanti_kapsaminda_mi" invisible="1"/>
                <field name="ariza_tipi" invisible="1"/>
                <field name="partner_id" invisible="1"/>
                <group>
                    <group>
                        <field name="musteri_adi" readonly="1"/>
                        <field name="urun" readonly="1"/>
                    </group>
                </group>
                <group attrs="{'invisible': [('garanti_kapsaminda_mi', '!=', 'urun_degisimi')]}">
                    <div class="alert alert-info" role="alert" attrs="{'invisible': [('garanti_kapsaminda_mi', '!=', 'urun_degisimi')]}">
                        <strong>📋 HATIRLATMA:</strong> Teslim Et butonu sonrası ürün değişimi için stok çıkış işlemlerini tamamlamayı unutmayınız.
                    </div>
                </group>
                <group attrs="{'invisible': [('onarim_ucreti', '&lt;=', 0)]}">
                    <div class="alert alert-warning" role="alert" attrs="{'invisible': [('onarim_ucreti', '&lt;=', 0)]}">
                        <strong>⚠️ UYARI:</strong> Bu kayıt için onarım ücreti bulunmaktadır. Teslim işlemi öncesinde Bakım &amp; Onarım siparişinin oluşturulduğundan ve ödemenin tamamlandığından emin olun!
                    </div>
                    <group>
                        <field name="onarim_ucreti" attrs="{'invisible': [('onarim_ucreti', '&lt;=', 0)]}"/>
                        <field name="odeme_tamamlandi" attrs="{'required': [('onarim_ucreti', '&gt;', 0)], 'invisible': [('onarim_ucreti', '&lt;=', 0)]}"/>
                    </group>
                </group>
                <group attrs="{'invisible': [('ariza_tipi', '=', 'magaza')]}">
                    <field name="adresime_gonderilsin"/>
                    <field name="musteri_adresi_id" options='{"no_create": false, "no_open": false}' context="{'default_parent_id': partner_id, 'default_type': 'delivery'}" attrs="{'invisible': [('adresime_gonderilsin', '=', False)], 'required': [('adresime_gonderilsin', '=', True)], 'readonly': [('adresime_gonderilsin', '=', False)]}"/>
                </group>
                <group>
                    <field name="teslim_alan" attrs="{'invisible': [('adresime_gonderilsin', '=', True)], 'required': [('adresime_gonderilsin', '=', False)]}" placeholder="Teslim alan kişinin adını girin"/>
                </group>
                <footer>
                    <button name="action_teslim_et" string="Teslim Et" type="object" class="btn-primary"/>
                    <button string="İptal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ariza_teslim_wizard" model="ir.actions.act_window">
        <field name="name">Teslim Alan Bilgisi</field>
        <field name="res_model">ariza.teslim.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_ariza_kayit"/>
    </record>
</odoo> 